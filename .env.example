# SAP System Connection
SAP_HOST=https://your-sap-server:44300
SAP_USER=your_username
# SAP_PASSWORD — NOT stored here, prompted interactively at startup
# For CI/automation only: set SAP_PASSWORD as env var at runtime
SAP_CLIENT=100
SAP_LANGUAGE=EN

# Server Configuration (for Streamable HTTP mode)
MCP_HOST=127.0.0.1
MCP_PORT=3122

# Logging
LOG_LEVEL=INFO
